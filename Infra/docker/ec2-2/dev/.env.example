# EC2 #2 dev 환경변수 예시
# 복사: cp .env.example .env
# .env 파일은 절대 Git에 커밋하지 말 것

# ── Redis (LLM 응답 캐시) ──
REDIS_LLM_PASSWORD=change_me_redis_llm_password

# ── AI LLM runtime (현재 AI 코드는 Ollama 환경변수를 사용) ──
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TEMPERATURE=0.1

# ── Anthropic Claude Opus 4.7 (Claude 전환 시 사용) ──
ANTHROPIC_API_KEY=sk-ant-your_api_key_here

# ── HasData API (참조 검색) ──
HASDATA_API_KEY=your_hasdata_api_key

# ── AWS S3 (EC2 #1과 동일 버킷) ──
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=ssafer-scan-results-dev

# ── 서버 간 통신 (EC2 #1과 동일한 값 사용) ──
# 생성: openssl rand -hex 32
INTERNAL_TOKEN=change_me_internal_token_min_32_chars
