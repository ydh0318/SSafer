# EC2 #2 prod 환경변수 예시
# 복사: cp .env.example .env && chmod 600 .env
# .env 파일은 절대 Git에 커밋하지 말 것

# ── AI LLM runtime ──
# ollama | anthropic | gms
LLM_PROVIDER=gms

# EC2 #2는 t3.large라 GPU 설정 없이 CPU로 Ollama를 실행합니다.
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_CONTAINER_NAME=ssafer-ollama
OLLAMA_VOLUME_NAME=ssafer-ollama-data
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_BACKOFF_SECONDS=1

# ── Optional external APIs ──
# Anthropic 공식 API 직접 호출을 켤 때 사용합니다.
ANTHROPIC_API_KEY=REPLACE
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_TEMPERATURE=0.1
ANTHROPIC_TIMEOUT_SECONDS=600

# GMS Anthropic-compatible gateway
GMS_API_KEY=REPLACE
GMS_BASE_URL=https://gms.ssafy.io/gmsapi/api.anthropic.com
GMS_MODEL=claude-haiku-4-5-20251001
GMS_TEMPERATURE=0.1
GMS_TIMEOUT_SECONDS=600
GMS_FORCE_JSON_RESPONSE_FORMAT=false

HASDATA_API_KEY=REPLACE

# ── AWS S3 ──
# raw/와 analysis/를 같은 bucket 안에서 prefix로 분리하는 구성입니다.
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_REGION=ap-northeast-2
APP_SCAN_RESULT_S3_BUCKET=ssafer-scan-storage-dev
APP_ANALYSIS_RESULT_S3_BUCKET=ssafer-scan-storage-dev

# ── EC2 #1 통신 ──
# EC2 #1과 #2는 서로 다른 AWS 계정/VPC에 있어 private IP로 통신 불가.
# 반드시 EC2 #1 public IP를 사용해야 한다.
# EC2 #1 public IP: 3.35.171.99

# ── Worker RabbitMQ ──
RABBITMQ_HOST=3.35.171.99
RABBITMQ_PORT=8989
RABBITMQ_USERNAME=ssafer
RABBITMQ_PASSWORD=REPLACE
RABBITMQ_VIRTUAL_HOST=/
AGENT_TASK_SCAN_REQUEST_QUEUE=ssafer.agent.scan.request

# ── Worker runtime ──
FASTAPI_BASE_URL=http://fastapi:8000
SPRING_BASE_URL=http://3.35.171.99:8080
SPRING_API_SECRET=REPLACE_WITH_EC2_1_WORKER_API_SECRET
WORKER_HTTP_TIMEOUT_SECONDS=600

# ── Docker Hub 이미지 (Jenkins CI가 push한 태그) ──
FASTAPI_IMAGE=your-dockerhub-org/ssafer-fastapi:latest
FASTAPI_CONTAINER_NAME=ssafer-fastapi
WORKER_CONTAINER_NAME=ssafer-ai-worker
FASTAPI_HOST_BIND_IP=0.0.0.0
FASTAPI_HOST_PORT=8000

# ── Docker compose runtime ──
COMPOSE_PROJECT_NAME=ssafer-ec2-prod
EC2_INTERNAL_NETWORK_NAME=ssafer-ec2-prod-internal
RESTART_POLICY=always
