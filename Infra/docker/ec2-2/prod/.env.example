# EC2 #2 prod 환경변수 예시
# 복사: cp .env.example .env && chmod 600 .env
# .env 파일은 절대 Git에 커밋하지 말 것

# ── Redis (LLM 응답 캐시) ──
REDIS_LLM_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── AI LLM runtime (현재 AI 코드는 Ollama 환경변수를 사용) ──
OLLAMA_BASE_URL=http://REPLACE_WITH_OLLAMA_HOST:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TEMPERATURE=0.1

# ── Anthropic Claude Opus 4.7 (Claude 전환 시 사용) ──
ANTHROPIC_API_KEY=sk-ant-REPLACE

# ── HasData API ──
HASDATA_API_KEY=REPLACE

# ── AWS S3 (EC2 #1과 동일 버킷) ──
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=ssafer-scan-results-prod

# ── EC2 #1 private IP (Spring 콜백 URL용) ──
# AWS 콘솔 → EC2 → 인스턴스 → Private IPv4 주소
EC2_1_PRIVATE_IP=10.0.x.x

# ── 서버 간 통신 (EC2 #1과 동일한 값) ──
# 생성: openssl rand -hex 32
INTERNAL_TOKEN=REPLACE_WITH_SHARED_SECRET

# ── Docker Hub 이미지 (Jenkins CI가 push한 태그) ──
FASTAPI_IMAGE=your-dockerhub-org/ssafer-fastapi:latest
