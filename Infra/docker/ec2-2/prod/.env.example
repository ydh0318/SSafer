# EC2 #2 prod 환경변수 예시
# 복사: cp .env.example .env && chmod 600 .env
# .env 파일은 절대 Git에 커밋하지 말 것

# ── AI LLM runtime (Ollama 기반) ──
OLLAMA_BASE_URL=http://172.17.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TEMPERATURE=0.1

# ── Anthropic Claude API (Claude 전환 시 사용) ──
ANTHROPIC_API_KEY=sk-ant-REPLACE

# ── HasData API (참조 검색) ──
HASDATA_API_KEY=REPLACE

# ── AWS S3 (EC2 #1과 동일 값) ──
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=REPLACE
APP_SCAN_RAW_S3_BUCKET=REPLACE
APP_ANALYSIS_RESULT_S3_BUCKET=REPLACE

# ── EC2 #1 통신 ──
# 변수명은 기존 compose 호환을 위해 EC2_1_PRIVATE_IP를 유지한다.
# 현재 EC2 #1/#2가 서로 다른 AWS 계정/VPC에 있어 실제 값은 EC2 #1 public IP를 입력한다.
EC2_1_PRIVATE_IP=3.35.171.99

# ── 서버 간 인증 토큰 (EC2 #1과 동일한 값) ──
# 생성: openssl rand -hex 32
INTERNAL_TOKEN=REPLACE_WITH_SHARED_SECRET

# ── Docker Hub 이미지 (Jenkins CI가 push한 태그) ──
FASTAPI_IMAGE=your-dockerhub-org/ssafer-fastapi:latest
