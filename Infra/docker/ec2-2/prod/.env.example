# EC2 #2 prod 환경변수 예시
# 복사: cp .env.example .env && chmod 600 .env
# .env 파일은 절대 Git에 커밋하지 말 것

# ── AI LLM runtime (Ollama 기반) ──
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_CONTAINER_NAME=ssafer-ollama
OLLAMA_PULL_CONTAINER_NAME=ssafer-ollama-pull
OLLAMA_VOLUME_NAME=ssafer-ollama-data
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_BACKOFF_SECONDS=1

# ── Anthropic Claude API (Claude 전환 시 사용) ──
ANTHROPIC_API_KEY=sk-ant-REPLACE

# ── HasData API (참조 검색) ──
HASDATA_API_KEY=REPLACE

# ── AWS S3 (EC2 #1과 동일 값) ──
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=REPLACE
APP_SCAN_RAW_S3_BUCKET=REPLACE
APP_ANALYSIS_RESULT_S3_BUCKET=REPLACE
S3_MAX_RETRIES=2
S3_RETRY_BACKOFF_SECONDS=1

# ── EC2 #1 통신 ──
SPRING_CALLBACK_URL=http://REPLACE_EC2_1_HOST:8080/api/v1/internal/callback

# ── 서버 간 인증 토큰 (EC2 #1과 동일한 값) ──
# 생성: openssl rand -hex 32
INTERNAL_TOKEN=REPLACE_WITH_SHARED_SECRET

# ── Docker Hub 이미지 (Jenkins CI가 push한 태그) ──
FASTAPI_IMAGE=your-dockerhub-org/ssafer-fastapi:latest
FASTAPI_CONTAINER_NAME=ssafer-fastapi
FASTAPI_HOST_PORT=8000
FASTAPI_ENV_FILE=.env

# ── Compose runtime ──
COMPOSE_PROJECT_NAME=ssafer-ec2-prod
EC2_INTERNAL_NETWORK_NAME=ssafer-ec2-prod-internal
RESTART_POLICY=always
