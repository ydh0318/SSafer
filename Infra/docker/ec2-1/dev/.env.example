# EC2 #1 dev 환경변수 예시
# 복사: cp .env.example .env
# .env 파일은 절대 Git에 커밋하지 말 것

# ── PostgreSQL ──
POSTGRES_DB=ssafer
POSTGRES_USER=ssafer
POSTGRES_PASSWORD=change_me_dev_password

# ── Redis (Spring 세션/캐시) ──
REDIS_PASSWORD=change_me_redis_password

# ── JWT ──
# 생성: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_min_32_chars_here
JWT_ISSUER=ssafer
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=7200

# ── AWS S3 ──
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=ssafer-scan-results-dev

# ── 서버 간 통신 (EC2 #2와 동일한 값 사용) ──
# 생성: openssl rand -hex 32
INTERNAL_TOKEN=change_me_internal_token_min_32_chars

# ── n8n ──
N8N_ENCRYPTION_KEY=change_me_n8n_encryption_key
N8N_DB_NAME=n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_basic_auth_password
