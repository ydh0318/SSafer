# EC2 #1 prod 환경변수 예시
# 복사: cp .env.example .env && chmod 600 .env
# .env 파일은 절대 Git에 커밋하지 말 것

# ── PostgreSQL ──
POSTGRES_DB=ssafer
POSTGRES_USER=ssafer
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Redis (Spring 세션/캐시) ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# RabbitMQ (Spring message broker)
RABBITMQ_USERNAME=REPLACE_WITH_RABBITMQ_USER
RABBITMQ_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── JWT ──
# 생성: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_256BIT_SECRET
JWT_ISSUER=ssafer
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=7200

# ── AWS S3 ──
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
APP_SCAN_RAW_S3_BUCKET=ssafer-scan-storage-prod
APP_SCAN_RAW_S3_REGION=ap-northeast-2

# ── Email verification (Resend) ──
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY
EMAIL_FROM_ADDRESS=auth@mg.ssafer.co.kr
EMAIL_VERIFICATION_CODE_TTL_SECONDS=300
EMAIL_VERIFICATION_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_VERIFIED_TTL_SECONDS=1800

# ── EC2 #2 private IP (VPC 내부) ──
# AWS 콘솔 → EC2 → 인스턴스 → Private IPv4 주소
EC2_2_PRIVATE_IP=10.0.x.x

# ── 서버 간 통신 (EC2 #2와 동일한 값) ──
# 생성: openssl rand -hex 32
INTERNAL_TOKEN=REPLACE_WITH_SHARED_SECRET

# ── n8n ──
N8N_ENCRYPTION_KEY=REPLACE_WITH_N8N_KEY
N8N_DB_NAME=n8n
N8N_EDITOR_BASE_URL=https://k14b105.p.ssafy.io/n8n/
GENERIC_TIMEZONE=Asia/Seoul
TZ=Asia/Seoul

# ── Docker Hub 이미지 (Jenkins CI가 push한 태그) ──
SPRING_IMAGE=REPLACE_WITH_DOCKERHUB_NAMESPACE/ssafer-spring:latest
NGINX_IMAGE=REPLACE_WITH_DOCKERHUB_NAMESPACE/ssafer-nginx:latest
