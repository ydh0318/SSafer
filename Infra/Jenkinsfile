def FAILED_STAGE = 'N/A'

pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    parameters {
        booleanParam(name: 'DEPLOY_EC2_2', defaultValue: false, description: 'Deploy FastAPI worker server on EC2 #2')
    }

    environment {
        DOCKERHUB_NAMESPACE = credentials('dockerhub-namespace')
        DOCKERHUB_CREDENTIALS = 'dockerhub-credentials'
        EC2_2_SSH_CREDENTIALS = 'ec2-2-ssh-key'
        DEPLOY_ROOT = '/var/lib/jenkins/ssafer/S14P31B105'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
        SPRING_IMAGE = "${DOCKERHUB_NAMESPACE}/ssafer-spring:${IMAGE_TAG}"
        FASTAPI_IMAGE = "${DOCKERHUB_NAMESPACE}/ssafer-fastapi:${IMAGE_TAG}"
        NGINX_IMAGE = "${DOCKERHUB_NAMESPACE}/ssafer-nginx:${IMAGE_TAG}"
        ENGINE_IMAGE = "${DOCKERHUB_NAMESPACE}/ssafer-engine:${IMAGE_TAG}"
    }

    stages {
        stage('Checkout') {
            steps {
                script { FAILED_STAGE = 'Checkout' }
                checkout scm
                script {
                    def changes = sh(script: '''
                        BASE_COMMIT="${GIT_PREVIOUS_SUCCESSFUL_COMMIT:-${GIT_PREVIOUS_COMMIT:-HEAD~1}}"
                        if git rev-parse --verify "$BASE_COMMIT" >/dev/null 2>&1; then
                          git diff --name-only "$BASE_COMMIT" HEAD
                        elif git rev-parse --verify HEAD~1 >/dev/null 2>&1; then
                          git diff --name-only HEAD~1 HEAD
                        else
                          echo ""
                        fi
                    ''', returnStdout: true).trim()
                    env.AUTO_DEPLOY_EC2_2 = (
                        changes.contains('AI/') ||
                        changes.contains('Infra/docker/ec2-2/') ||
                        changes.contains('Infra/docker/dockerfiles/Dockerfile.fastapi') ||
                        changes.contains('Infra/scripts/deploy-ec2-2.sh')
                    ) ? 'true' : 'false'
                    env.AUTO_REBUILD_ENGINE = (
                        changes.contains('CLI/') ||
                        changes.contains('Engine/') ||
                        changes.contains('Infra/docker/dockerfiles/Dockerfile.engine')
                    ) ? 'true' : 'false'
                    if (env.AUTO_REBUILD_ENGINE == 'true') {
                        echo "Engine related changes detected. Engine image will be rebuilt."
                    }
                    if (env.AUTO_DEPLOY_EC2_2 == 'true') {
                        echo "EC2 #2 related changes detected. Auto deploy enabled."
                    } else {
                        echo "No EC2 #2 related changes detected. EC2 #2 deploy skipped unless DEPLOY_EC2_2=true."
                    }
                }
            }
        }

        stage('Build Images') {
            steps {
                script { FAILED_STAGE = 'Build Images' }
                sh '''
                    ENV_FILE="$DEPLOY_ROOT/Infra/docker/ec2-1/prod/.env"

                    read_env_value() {
                      key="$1"
                      grep "^${key}=" "$ENV_FILE" | tail -n 1 | cut -d'=' -f2-
                    }

                    APP_BASE_URL="$(read_env_value APP_BASE_URL)"
                    VITE_API_BASE_URL="$(read_env_value VITE_API_BASE_URL)"
                    VITE_GOOGLE_CLIENT_ID="$(read_env_value VITE_GOOGLE_CLIENT_ID)"
                    VITE_GITHUB_CLIENT_ID="$(read_env_value VITE_GITHUB_CLIENT_ID)"

                    if [ -z "$VITE_API_BASE_URL" ] && [ -n "$APP_BASE_URL" ]; then
                      VITE_API_BASE_URL="${APP_BASE_URL%/}/api/v1"
                    fi

                    : "${VITE_API_BASE_URL:?VITE_API_BASE_URL is required for frontend build}"
                    : "${VITE_GOOGLE_CLIENT_ID:?VITE_GOOGLE_CLIENT_ID is required for frontend OAuth build}"
                    : "${VITE_GITHUB_CLIENT_ID:?VITE_GITHUB_CLIENT_ID is required for frontend OAuth build}"

                    docker build -f Infra/docker/dockerfiles/Dockerfile.spring -t "$SPRING_IMAGE" .
                    docker build -f Infra/docker/dockerfiles/Dockerfile.fastapi -t "$FASTAPI_IMAGE" .
                    docker build -f Infra/docker/dockerfiles/Dockerfile.engine -t "$ENGINE_IMAGE" .
                    docker build -f Infra/docker/dockerfiles/nginx/Dockerfile \
                      --build-arg VITE_API_BASE_URL="$VITE_API_BASE_URL" \
                      --build-arg VITE_GOOGLE_CLIENT_ID="$VITE_GOOGLE_CLIENT_ID" \
                      --build-arg VITE_GITHUB_CLIENT_ID="$VITE_GITHUB_CLIENT_ID" \
                      -t "$NGINX_IMAGE" .
                '''
            }
        }

        stage('Push Images') {
            steps {
                script { FAILED_STAGE = 'Push Images' }
                withCredentials([usernamePassword(credentialsId: env.DOCKERHUB_CREDENTIALS, usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASSWORD')]) {
                    sh '''
                        echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USER" --password-stdin
                        docker push "$SPRING_IMAGE"
                        docker push "$FASTAPI_IMAGE"
                        docker push "$NGINX_IMAGE"
                        docker push "$ENGINE_IMAGE"
                        docker logout
                    '''
                }
            }
        }

        stage('Sync EC2 #1 Deploy Files') {
            steps {
                script { FAILED_STAGE = 'Sync EC2 #1 Deploy Files' }
                sh '''
                    mkdir -p "$DEPLOY_ROOT/Infra/docker/ec2-1/prod"
                    mkdir -p "$DEPLOY_ROOT/Infra/scripts"
                    cp -R Infra/docker/ec2-1/prod/* "$DEPLOY_ROOT/Infra/docker/ec2-1/prod/"
                    cp Infra/scripts/deploy-ec2-1.sh "$DEPLOY_ROOT/Infra/scripts/deploy-ec2-1.sh"
                    chmod +x "$DEPLOY_ROOT/Infra/scripts/deploy-ec2-1.sh"
                '''
            }
        }

        stage('Deploy EC2 #1') {
            steps {
                script { FAILED_STAGE = 'Deploy EC2 #1' }
                sh '''
                    SPRING_IMAGE="$SPRING_IMAGE" NGINX_IMAGE="$NGINX_IMAGE" ENGINE_IMAGE="$ENGINE_IMAGE" \
                    bash "$DEPLOY_ROOT/Infra/scripts/deploy-ec2-1.sh"
                '''
            }
        }

        stage('Sync EC2 #2 Deploy Files') {
            when {
                expression { return params.DEPLOY_EC2_2 || env.AUTO_DEPLOY_EC2_2 == 'true' }
            }
            steps {
                script { FAILED_STAGE = 'Sync EC2 #2 Deploy Files' }
                withCredentials([string(credentialsId: 'ec2-2-host', variable: 'EC2_2_HOST')]) {
                    sshagent(credentials: [env.EC2_2_SSH_CREDENTIALS]) {
                        sh '''
                            ssh -o StrictHostKeyChecking=no ubuntu@"$EC2_2_HOST" \
                              'mkdir -p /home/ubuntu/ssafer/S14P31B105/Infra/docker/ec2-2/prod /home/ubuntu/ssafer/S14P31B105/Infra/scripts'
                            scp -o StrictHostKeyChecking=no \
                              Infra/docker/ec2-2/prod/docker-compose.yml \
                              ubuntu@"$EC2_2_HOST":/home/ubuntu/ssafer/S14P31B105/Infra/docker/ec2-2/prod/
                            scp -o StrictHostKeyChecking=no \
                              Infra/scripts/deploy-ec2-2.sh \
                              ubuntu@"$EC2_2_HOST":/home/ubuntu/ssafer/S14P31B105/Infra/scripts/
                            ssh -o StrictHostKeyChecking=no ubuntu@"$EC2_2_HOST" \
                              'chmod +x /home/ubuntu/ssafer/S14P31B105/Infra/scripts/deploy-ec2-2.sh'
                        '''
                    }
                }
            }
        }

        stage('Deploy EC2 #2') {
            when {
                expression { return params.DEPLOY_EC2_2 || env.AUTO_DEPLOY_EC2_2 == 'true' }
            }
            steps {
                script { FAILED_STAGE = 'Deploy EC2 #2' }
                withCredentials([string(credentialsId: 'ec2-2-host', variable: 'EC2_2_HOST')]) {
                    sshagent(credentials: [env.EC2_2_SSH_CREDENTIALS]) {
                        sh """
                            ssh -o StrictHostKeyChecking=no ubuntu@"\$EC2_2_HOST" \
                              "FASTAPI_IMAGE='${env.FASTAPI_IMAGE}' bash /home/ubuntu/ssafer/S14P31B105/Infra/scripts/deploy-ec2-2.sh"
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            sh(script: 'docker image prune -f || true', returnStatus: true)
        }
        success {
            withCredentials([string(credentialsId: 'mattermost-webhook-url', variable: 'MM_WEBHOOK')]) {
                script {
                    def commitMsg = sh(script: 'git log -1 --format=%s', returnStdout: true).trim()
                    def duration = currentBuild.durationString.replace(' and counting', '')
                    def msg = "✅ **[SSafer] 배포 성공**\n" +
                              "> **브랜치:** `${env.GIT_BRANCH}`\n" +
                              "> **커밋:** ${commitMsg}\n" +
                              "> **이미지 태그:** `${env.IMAGE_TAG}`\n" +
                              "> **소요 시간:** ${duration}\n" +
                              "> **빌드:** [#${env.BUILD_NUMBER} 바로가기](${env.BUILD_URL})"
                    def payload = groovy.json.JsonOutput.toJson([username: 'Jenkins Bot', text: msg])
                    writeFile file: '/tmp/mm_payload.json', text: payload
                    sh 'curl -s -X POST "$MM_WEBHOOK" -H "Content-Type: application/json" -d @/tmp/mm_payload.json'
                }
            }
        }
        failure {
            withCredentials([string(credentialsId: 'mattermost-webhook-url', variable: 'MM_WEBHOOK')]) {
                script {
                    def commitMsg = sh(script: 'git log -1 --format=%s', returnStdout: true).trim()
                    def duration = currentBuild.durationString.replace(' and counting', '')
                    def msg = "❌ **[SSafer] 배포 실패**\n" +
                              "> **브랜치:** `${env.GIT_BRANCH}`\n" +
                              "> **커밋:** ${commitMsg}\n" +
                              "> **소요 시간:** ${duration}\n" +
                              "> **실패 Stage:** `${FAILED_STAGE}`\n" +
                              "> **빌드:** [#${env.BUILD_NUMBER} 바로가기](${env.BUILD_URL})\n" +
                              "> **콘솔 로그:** [확인하기](${env.BUILD_URL}console)"
                    def payload = groovy.json.JsonOutput.toJson([username: 'Jenkins Bot', text: msg])
                    writeFile file: '/tmp/mm_payload.json', text: payload
                    sh 'curl -s -X POST "$MM_WEBHOOK" -H "Content-Type: application/json" -d @/tmp/mm_payload.json'
                }
            }
        }
    }
}
