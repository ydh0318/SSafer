# Frontend runtime configuration for Vite
#
# Local development:
# - `VITE_API_BASE_URL` can usually stay as `/api/v1` when using the Vite dev proxy.
# - `VITE_GOOGLE_CLIENT_ID` must match the Google OAuth Web Client configured for
#   the same redirect URI you use in the browser.
# - `VITE_GITHUB_CLIENT_ID` must match the GitHub OAuth App that uses the same
#   callback URL.
#
# Google redirect URI examples to register in Google Console:
# - http://localhost:5173/oauth/google/callback
# - https://ssafer.co.kr/oauth/google/callback
#
# GitHub callback URL examples:
# - http://localhost:5173/oauth/github/callback
# - https://ssafer.co.kr/oauth/github/callback

VITE_API_BASE_URL=/api/v1
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GITHUB_CLIENT_ID=your-github-oauth-client-id

# OAuth redirect base URL — GitHub / Google OAuth App에 등록된 도메인으로 설정하세요.
# 비워두면 window.location.origin을 자동 사용합니다.
# 예) 로컬: http://localhost:5173
#     운영: https://ssafer.co.kr
VITE_OAUTH_REDIRECT_BASE_URL=
