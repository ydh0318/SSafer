# ── LLM Provider ──
# ollama | anthropic | gms
LLM_PROVIDER=gms

# ── Ollama ──
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_BACKOFF_SECONDS=1

# ── Anthropic ──
ANTHROPIC_API_KEY=REPLACE
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_TEMPERATURE=0.1
ANTHROPIC_TIMEOUT_SECONDS=600

# ── GMS / OpenAI-compatible gateway ──
GMS_API_KEY=REPLACE
GMS_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
GMS_MODEL=gpt-5-mini
GMS_TEMPERATURE=0.1
GMS_TIMEOUT_SECONDS=600
GMS_FORCE_JSON_RESPONSE_FORMAT=false

# ── LLM output token limits ──
LLM_EXPLAIN_MAX_TOKENS=900
LLM_FIX_MAX_TOKENS=2000

# ── AWS S3 ──
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_REGION=ap-northeast-2
APP_SCAN_RAW_S3_BUCKET=ssafer-scan-storage-dev
APP_ANALYSIS_RESULT_S3_BUCKET=ssafer-scan-storage-dev
S3_MAX_RETRIES=2
S3_RETRY_BACKOFF_SECONDS=1

# Worker
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/
AGENT_TASK_SCAN_REQUEST_QUEUE=ssafer.agent.scan.request
FASTAPI_BASE_URL=http://127.0.0.1:8000
SPRING_BASE_URL=http://127.0.0.1:8080
SPRING_API_SECRET=REPLACE
WORKER_HTTP_TIMEOUT_SECONDS=120
WORKER_MAX_CONCURRENCY=5
WORKER_SHUTDOWN_TIMEOUT_SECONDS=1800
MAX_LLM_CONCURRENCY=10
MAX_FINDING_CONCURRENCY=5

# LocalStack/MinIO 같은 S3 호환 저장소를 사용할 때만 설정합니다.
# AWS_S3_ENDPOINT_URL=http://localhost:4566
