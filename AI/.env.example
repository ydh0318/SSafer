# AI 로컬 환경변수 예시 (EC2 #2 prod 기준)
# 복사: cp .env.example .env && chmod 600 .env
# .env 파일은 절대 Git에 커밋하지 말 것

# -- AI LLM runtime --
LLM_PROVIDER=gms
LLM_EXPLAIN_MAX_TOKENS=900
LLM_FIX_MAX_TOKENS=2000
LLM_VERIFY_MAX_TOKENS=200

# Docker compose로 띄울 때만 사용 (로컬 venv 실행 시 무시됨)
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_CONTAINER_NAME=ssafer-ollama
OLLAMA_VOLUME_NAME=ssafer-ollama-data
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_BACKOFF_SECONDS=1

ANTHROPIC_API_KEY=REPLACE
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_TEMPERATURE=0.1
ANTHROPIC_TIMEOUT_SECONDS=600

GMS_API_KEY=REPLACE
# optional
# GMS_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
# GMS_MODEL=gpt-5-mini
GMS_BASE_URL=https://gms.ssafy.io/gmsapi/api.anthropic.com
GMS_MODEL=claude-haiku-4-5-20251001
GMS_TEMPERATURE=0.1
GMS_TIMEOUT_SECONDS=600
GMS_FORCE_JSON_RESPONSE_FORMAT=false

# ── Verify (self-evaluation) ──
VERIFY_ENABLED=true
VERIFY_LLM_ENABLED=true
MAX_VERIFY_RETRIES=1

# ── Tool-calling Agent ──
AGENT_ENABLED=false
AGENT_MAX_ITERATIONS=3
NVD_API_KEY=REPLACE

# ── HasData (Web Reference Search) ──
HASDATA_API_KEY=REPLACE
HASDATA_ENABLED=true
HASDATA_MAX_RESULTS=5
HASDATA_TIMEOUT_SECONDS=30

# ── LangSmith (Agent tracing 시각화, 선택) ──
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=REPLACE
LANGSMITH_PROJECT=ssafer

# -- AWS S3 --
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=ssafer-scan-storage-dev
APP_SCAN_RAW_S3_BUCKET=ssafer-scan-storage-dev
APP_SCAN_RESULT_S3_BUCKET=ssafer-scan-storage-dev
APP_ANALYSIS_RESULT_S3_BUCKET=ssafer-scan-storage-dev
S3_MAX_RETRIES=2
S3_RETRY_BACKOFF_SECONDS=1

# -- RabbitMQ --
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/
AGENT_TASK_SCAN_REQUEST_QUEUE=ssafer.agent.scan.request

# -- Worker runtime --
FASTAPI_BASE_URL=http://127.0.0.1:8000
SPRING_BASE_URL=http://127.0.0.1:8080
SPRING_API_SECRET=
WORKER_HTTP_TIMEOUT_SECONDS=120

# 병렬처리 관련 환경변수
WORKER_MAX_CONCURRENCY=5
WORKER_SHUTDOWN_TIMEOUT_SECONDS=1800
MAX_LLM_CONCURRENCY=10
MAX_FINDING_CONCURRENCY=5

# -- Docker Hub 이미지 (Docker compose로 띄울 때만 사용) --
FASTAPI_IMAGE=helow/ssafer-fastapi:latest
FASTAPI_CONTAINER_NAME=ssafer-fastapi
WORKER_CONTAINER_NAME=ssafer-ai-worker
FASTAPI_HOST_BIND_IP=0.0.0.0
FASTAPI_HOST_PORT=8000

# -- Docker compose runtime --
COMPOSE_PROJECT_NAME=ssafer-ec2-prod
EC2_INTERNAL_NETWORK_NAME=ssafer-ec2-prod-internal
RESTART_POLICY=always

# LocalStack/MinIO 같은 S3 호환 저장소를 사용할 때만 설정합니다.
# AWS_S3_ENDPOINT_URL=http://localhost:4566
